# AFB Mangaan Attendance System - Environment Configuration
# Copy this file to .env and update the values

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=afb_mangaan_db
DB_USER=root
DB_PASSWORD=

# QR Code Prefix (e.g., AFB)
QR_PREFIX=AFB

# Security Settings
WEBHOOK_SECRET=change-this-to-a-random-secret-key-at-least-32-characters

# make.com Integration (Optional)
# Get this URL from your make.com webhook module
MAKE_WEBHOOK_URL=https://hook.make.com/your-webhook-url-here

# Webhook Logging (true/false)
WEBHOOK_LOGGING=true

# Session/Cookie Settings (optional)
SESSION_LIFETIME=7200
